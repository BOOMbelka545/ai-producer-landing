{
  "name": "landing-site",
  "version": "1.0.0",
  "private": true,
  "description": "Landing CI quality gates and build scripts",
  "scripts": {
    "lint:html": "htmlhint index.html --config .htmlhintrc.json",
    "lint:css": "stylelint styles.css --config .stylelintrc.json",
    "lint:js": "eslint script.js --config .eslintrc.cjs",
    "build": "bash ./scripts/build-static.sh",
    "smoke": "bash ./scripts/smoke-check.sh ./dist/site",
    "audit": "npm audit --audit-level=high"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "htmlhint": "^1.1.4",
    "stylelint": "^16.16.0",
    "stylelint-config-standard": "^36.0.1"
  }
}
